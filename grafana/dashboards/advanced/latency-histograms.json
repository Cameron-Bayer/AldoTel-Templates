          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "interval": "1m"
    },
    {
      "id": null,
      "type": "timeseries",
      "title": "Server request rate by service (per interval)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT time, service, sum(dcount) AS requests FROM (\n  SELECT $__timeInterval(TimeUnix) AS time, ServiceName AS service,\n         max(Sum) - min(Sum) AS dsum, max(Count) - min(Count) AS dcount\n  FROM ${database}.otel_metrics_histogram\n  WHERE MetricName IN ('http.server.duration') AND $__timeFilter(TimeUnix) AND ServiceName IN (${service:sqlstring})\n  GROUP BY service, ResourceAttributes['service.instance.id'], toString(Attributes), time)\nGROUP BY time, service ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "interval": "1m"
    },
    {
      "id": null,
      "type": "table",
      "title": "Latency by service & operation (avg)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT service AS \"Service\", metric AS \"Metric\",\n       round(sum(dsum) / greatest(sum(dcount), 1), 2) AS \"Avg ms\",\n       toUInt64(sum(dcount)) AS \"Requests\"\nFROM (\n  SELECT ServiceName AS service, MetricName AS metric,\n         max(Sum) - min(Sum) AS dsum, max(Count) - min(Count) AS dcount\n  FROM ${database}.otel_metrics_histogram\n  WHERE MetricName IN ('http.server.duration', 'http.client.duration', 'rpc.server.duration') AND $__timeFilter(TimeUnix) AND ServiceName IN (${service:sqlstring})\n  GROUP BY service, metric, ResourceAttributes['service.instance.id'], toString(Attributes))\nGROUP BY service, metric\nHAVING \"Requests\" > 0\nORDER BY \"Requests\" DESC\nLIMIT 30",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Avg ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
