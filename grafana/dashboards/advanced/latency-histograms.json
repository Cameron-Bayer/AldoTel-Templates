    {
      "id": null,
      "type": "timeseries",
      "title": "Avg server latency by service (ms)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT time, service, sum(dsum) / greatest(sum(dcount), 1) AS \"avg ms\" FROM (\n  SELECT $__timeInterval(TimeUnix) AS time, ServiceName AS service,\n         max(Sum) - min(Sum) AS dsum, max(Count) - min(Count) AS dcount\n  FROM ${database}.otel_metrics_histogram\n  WHERE MetricName IN ('http.server.duration') AND $__timeFilter(TimeUnix) AND ServiceName IN (${service:sqlstring})\n  GROUP BY service, ResourceAttributes['service.instance.id'], toString(Attributes), time)\nGROUP BY time, service ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
