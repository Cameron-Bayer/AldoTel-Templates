          "uid": "${clickhouseDatasource}"
        },
        "definition": "SELECT DISTINCT ServiceName FROM ${database}.otel_metrics_histogram WHERE $__timeFilter(TimeUnix) AND ServiceName != '' ORDER BY ServiceName",
        "query": {
          "refId": "service-var",
          "rawSql": "SELECT DISTINCT ServiceName FROM ${database}.otel_metrics_histogram WHERE $__timeFilter(TimeUnix) AND ServiceName != '' ORDER BY ServiceName",
