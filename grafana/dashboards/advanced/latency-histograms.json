          },
          "editorType": "sql",
          "rawSql": "SELECT sum(dsum) / greatest(sum(dcount), 1) AS value FROM (\n  SELECT ServiceName AS service,\n         max(Sum) - min(Sum) AS dsum, max(Count) - min(Count) AS dcount\n  FROM ${database}.otel_metrics_histogram\n  WHERE MetricName IN ('http.client.duration') AND $__timeFilter(TimeUnix) AND ServiceName IN (${service:sqlstring})\n  GROUP BY service, ResourceAttributes['service.instance.id'], toString(Attributes))",
