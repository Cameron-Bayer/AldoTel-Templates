{
  "uid": "clickstack-logs-overview",
  "title": "ClickStack · Logs & Errors Overview",
  "description": "Log throughput and error analysis from OpenTelemetry logs in ClickHouse (otel_logs): volume by severity, error rate, and recent errors.",
  "tags": [
    "clickstack",
    "opentelemetry"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "ClickHouse datasource",
        "multi": false,
        "name": "clickhouseDatasource",
        "options": [],
        "query": "grafana-clickhouse-datasource",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "name": "database",
        "label": "ClickHouse database",
        "type": "constant",
        "query": "default",
        "current": {
          "value": "default",
          "text": "default",
          "selected": false
        },
        "options": [
          {
            "value": "default",
            "text": "default",
            "selected": false
          }
        ],
        "hide": 2,
        "skipUrlSync": false
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "grafana-clickhouse-datasource",
          "uid": "${clickhouseDatasource}"
        },
        "definition": "SELECT DISTINCT ServiceName FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName != '' ORDER BY ServiceName",
        "query": {
          "refId": "service-var",
          "rawSql": "SELECT DISTINCT ServiceName FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName != '' ORDER BY ServiceName",
          "meta": {
            "builderOptions": {
              "database": "default"
            }
          }
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": false
        },
        "options": [],
        "hide": 0,
        "sort": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": null,
      "type": "stat",
      "title": "Logs / sec",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT count() / dateDiff('second', $__fromTime, $__toTime) AS value FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring})",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": null,
      "type": "stat",
      "title": "Error+ logs / sec",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT countIf((SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))) / dateDiff('second', $__fromTime, $__toTime) AS value FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring})",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": {
            "mode": "thresholds",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": null,
      "type": "stat",
      "title": "Error log %",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT 100 * countIf((SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))) / nullIf(count(), 0) AS value FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring})",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": null,
      "type": "stat",
      "title": "Fatal logs",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT countIf((SeverityNumber >= 21 OR lower(SeverityText) = 'fatal')) AS value FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring})",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": null,
      "type": "timeseries",
      "title": "Log volume by severity",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, multiIf(SeverityNumber >= 21, 'fatal', SeverityNumber >= 17, 'error', SeverityNumber >= 13, 'warn', SeverityNumber >= 9, 'info', SeverityNumber >= 5, 'debug', SeverityNumber >= 1, 'trace', SeverityText != '', lower(SeverityText), 'unspecified') AS severity, count() AS logs\nFROM ${database}.otel_logs\nWHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring})\nGROUP BY time, severity ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "interval": "1m"
    },
    {
      "id": null,
      "type": "timeseries",
      "title": "Error+ logs by service",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, ServiceName AS service, count() AS errors\nFROM ${database}.otel_logs\nWHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring}) AND (SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))\nGROUP BY time, service HAVING errors > 0 ORDER BY time",
          "queryType": "timeseries",
          "format": 0,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "interval": "1m"
    },
    {
      "id": null,
      "type": "table",
      "title": "Top services by error+ logs",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT ServiceName AS \"Service\",\n       count() AS \"Error logs\",\n       round(100 * count() / nullIf((SELECT count() FROM ${database}.otel_logs WHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring}) AND (SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))), 0), 1) AS \"% of errors\"\nFROM ${database}.otel_logs\nWHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring}) AND (SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))\nGROUP BY 1 ORDER BY 2 DESC LIMIT 15",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "% of errors"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    },
    {
      "id": null,
      "type": "table",
      "title": "Recent errors",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT Timestamp AS \"Time\",\n       ServiceName AS \"Service\",\n       multiIf(SeverityNumber >= 21, 'fatal', SeverityNumber >= 17, 'error', SeverityNumber >= 13, 'warn', SeverityNumber >= 9, 'info', SeverityNumber >= 5, 'debug', SeverityNumber >= 1, 'trace', SeverityText != '', lower(SeverityText), 'unspecified') AS \"Severity\",\n       substring(Body, 1, 200) AS \"Message\"\nFROM ${database}.otel_logs\nWHERE $__timeFilter(Timestamp) AND ServiceName IN (${service:sqlstring}) AND (SeverityNumber >= 17 OR lower(SeverityText) IN ('error', 'fatal'))\nORDER BY Timestamp DESC LIMIT 100",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      }
    }
  ]
}
