            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT count() / dateDiff('second', $__fromTime, $__toTime) AS value FROM ${database}.otel_traces WHERE $__timeFilter(Timestamp) AND SpanKind = 'Server'",
