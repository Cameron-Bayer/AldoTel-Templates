          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT $__timeInterval(Timestamp) AS time, count() AS requests\nFROM ${database}.otel_traces WHERE $__timeFilter(Timestamp) AND SpanKind = 'Server'\nGROUP BY time ORDER BY time",
          "queryType": "timeseries",
