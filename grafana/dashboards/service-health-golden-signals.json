          "editorType": "sql",
          "rawSql": "SELECT ServiceName AS \"Service\",\n       round(count() / dateDiff('second', $__fromTime, $__toTime), 2) AS \"Req/s\",\n       countIf(StatusCode = 'Error') AS \"Errors\",\n       round(100 * countIf(StatusCode = 'Error') / nullIf(count(), 0), 2) AS \"Error %\",\n       round(quantile(0.50)(Duration) / 1e6, 1) AS \"p50 ms\",\n       round(quantile(0.95)(Duration) / 1e6, 1) AS \"p95 ms\",\n       round(quantile(0.99)(Duration) / 1e6, 1) AS \"p99 ms\"\nFROM ${database}.otel_traces\nWHERE $__timeFilter(Timestamp) AND SpanKind = 'Server' AND ServiceName IN (${service:sqlstring})\nGROUP BY ServiceName\nORDER BY count() DESC",
