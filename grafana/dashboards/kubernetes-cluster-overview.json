    {
      "id": null,
      "type": "table",
      "title": "Top pods by memory (working set)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${clickhouseDatasource}"
          },
          "editorType": "sql",
          "rawSql": "SELECT ResourceAttributes['k8s.namespace.name'] AS \"Namespace\",\n       ResourceAttributes['k8s.pod.name'] AS \"Pod\",\n       argMax(Value, TimeUnix) AS \"Memory\"\nFROM ${database}.otel_metrics_gauge\nWHERE MetricName = 'k8s.pod.memory.working_set' AND $__timeFilter(TimeUnix) AND ResourceAttributes['k8s.namespace.name'] IN (${namespace:sqlstring})\nGROUP BY 1, 2\nORDER BY \"Memory\" DESC\nLIMIT 20",
          "queryType": "table",
          "format": 1,
          "meta": {
            "builderOptions": {
              "database": "default",
              "mode": "trend"
            }
          }
        }
