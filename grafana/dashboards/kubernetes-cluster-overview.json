    {
      "id": null,
      "type": "table",
      "title": "Container restarts (by pod)",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${clickhouseDatasource}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
