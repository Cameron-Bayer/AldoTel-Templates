# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored by
# convention — do NOT commit real tokens or webhook URLs.

grafana_url  = "https://YOUR-ORG.grafana.net"        # or http://localhost:3000
grafana_auth = "glsa_XXXXXXXXXXXXXXXXXXXX"           # service account token

# The ClickHouse data source must already exist in Grafana. Put its UID here.
clickhouse_datasource_uid = "clickstack-ch"
clickhouse_database       = "default"

# Webhook URL alerts POST to — your own on-call integration (Slack incoming
# webhook, a Teams Workflow URL, PagerDuty, Discord, or any HTTP endpoint).
alert_webhook_url = "https://REPLACE-WITH-YOUR-WEBHOOK-URL"

# Optional: override the default thresholds.
# error_rate_pct            = 5
# p95_latency_ms            = 2000
# error_log_rate_per_sec    = 5
# slo_burn_rate             = 14.4
# ch_failed_queries_per_sec = 1
