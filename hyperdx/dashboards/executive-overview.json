{
  "name": "ClickStack · Executive Overview",
  "tags": [
    "clickstack-templates",
    "overview",
    "tmpl:exec-overview"
  ],
  "filters": [
    {
      "type": "QUERY_EXPRESSION",
      "name": "Service",
      "expression": "ServiceName",
      "sourceId": "{{TRACES_SOURCE_ID}}",
      "whereLanguage": "sql"
    },
    {
      "type": "QUERY_EXPRESSION",
      "name": "Namespace",
      "expression": "ResourceAttributes['k8s.namespace.name']",
      "sourceId": "{{METRICS_SOURCE_ID}}",
      "sourceMetricType": "gauge",
      "whereLanguage": "sql"
    }
  ],
  "tiles": [
    {
      "name": "",
      "x": 0,
      "y": 0,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Service health — at a glance"
      }
    },
    {
      "name": "Server error rate (%)",
      "x": 0,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "if(StatusCode = 'Error', 1, 0)",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ],
        "colorRules": [
          {
            "operator": "gt",
            "value": 0.01,
            "color": "chart-warning",
            "label": "Elevated"
          },
          {
            "operator": "gt",
            "value": 0.05,
            "color": "chart-error",
            "label": "High"
          }
        ]
      }
    },
    {
      "name": "Server requests (spans)",
      "x": 6,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "count",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Server latency p95",
      "x": 12,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "duration"
        },
        "select": [
          {
            "aggFn": "quantile",
            "level": 0.95,
            "valueExpression": "Duration / 1000000000",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Log error rate (%)",
      "x": 18,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{LOGS_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "if(SeverityNumber >= 17 OR lower(SeverityText) IN ('error','fatal'), 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "colorRules": [
          {
            "operator": "gt",
            "value": 0.01,
            "color": "chart-warning",
            "label": "Elevated"
          },
          {
            "operator": "gt",
            "value": 0.05,
            "color": "chart-error",
            "label": "High"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 7,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Platform — at a glance"
      }
    },
    {
      "name": "K8s nodes ready",
      "x": 0,
      "y": 10,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT countIf(ready = 1) AS \"Nodes ready\" FROM (\n  SELECT ResourceAttributes['k8s.node.name'] AS node, argMax(Value, TimeUnix) AS ready\n  FROM {{METRICS_SCHEMA}}.otel_metrics_gauge\n  WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND MetricName = 'k8s.node.condition_ready'\n  GROUP BY node\n)"
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 14,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Top services"
      }
    },
    {
      "name": "Services by error rate — click a row to open Traces",
      "x": 0,
      "y": 17,
      "w": 12,
      "h": 7,
      "config": {
        "displayType": "table",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "groupByColumnsOnLeft": true,
        "orderBy": "err_pct DESC",
        "select": [
          {
            "alias": "spans",
            "aggFn": "count",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          },
          {
            "alias": "err_pct",
            "aggFn": "avg",
            "valueExpression": "if(StatusCode = 'Error', 100, 0)",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ],
        "onClick": {
          "type": "search",
          "target": {
            "mode": "id",
            "id": "{{TRACES_SOURCE_ID}}"
          },
          "whereTemplate": "ServiceName = '{{ServiceName}}'",
          "whereLanguage": "sql"
        }
      }
    },
    {
      "name": "Services by log errors — click a row to open Logs",
      "x": 12,
      "y": 17,
      "w": 12,
      "h": 7,
      "config": {
        "displayType": "table",
        "sourceId": "{{LOGS_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "groupByColumnsOnLeft": true,
        "orderBy": "errors DESC",
        "select": [
          {
            "alias": "logs",
            "aggFn": "count",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "alias": "errors",
            "aggFn": "sum",
            "valueExpression": "if(SeverityNumber >= 17 OR lower(SeverityText) IN ('error','fatal'), 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "onClick": {
          "type": "search",
          "target": {
            "mode": "id",
            "id": "{{LOGS_SOURCE_ID}}"
          },
          "whereTemplate": "ServiceName = '{{ServiceName}}'",
          "whereLanguage": "sql"
        }
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 24,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Request traffic"
      }
    },
    {
      "name": "Request rate & errors (traces)",
      "x": 0,
      "y": 27,
      "w": 24,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "select": [
          {
            "alias": "requests",
            "aggFn": "count",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          },
          {
            "alias": "errors",
            "aggFn": "sum",
            "valueExpression": "if(StatusCode = 'Error', 1, 0)",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ]
      }
    }
  ]
}
