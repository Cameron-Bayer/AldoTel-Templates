{
  "name": "ClickStack · Services — RED (Rate / Errors / Duration)",
  "tags": [
    "clickstack-templates",
    "apm",
    "traces",
    "tmpl:services-red"
  ],
  "filters": [
    {
      "type": "QUERY_EXPRESSION",
      "name": "Service",
      "expression": "ServiceName",
      "sourceId": "{{TRACES_SOURCE_ID}}",
      "whereLanguage": "sql"
    }
  ],
  "tiles": [
    {
      "name": "",
      "x": 0,
      "y": 0,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Rate & errors"
      }
    },
    {
      "name": "Request rate by service",
      "x": 0,
      "y": 3,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "select": [
          {
            "aggFn": "count",
            "alias": "requests",
            "where": "SpanKind:Server",
            "whereLanguage": "lucene"
          }
        ]
      }
    },
    {
      "name": "Error rate %",
      "x": 12,
      "y": 3,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "asRatio": true,
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "count",
            "alias": "errors",
            "where": "SpanKind:Server AND StatusCode:Error",
            "whereLanguage": "lucene"
          },
          {
            "aggFn": "count",
            "alias": "total",
            "where": "SpanKind:Server",
            "whereLanguage": "lucene"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 9,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Latency & error breakdown"
      }
    },
    {
      "name": "Latency p50 / p95 / p99",
      "x": 0,
      "y": 12,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "quantile",
            "level": 0.5,
            "valueExpression": "Duration / 1000000000",
            "alias": "p50",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          },
          {
            "aggFn": "quantile",
            "level": 0.95,
            "valueExpression": "Duration / 1000000000",
            "alias": "p95",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          },
          {
            "aggFn": "quantile",
            "level": 0.99,
            "valueExpression": "Duration / 1000000000",
            "alias": "p99",
            "where": "SpanKind = 'Server'",
            "whereLanguage": "sql"
          }
        ],
        "numberFormat": {
          "output": "duration"
        }
      }
    },
    {
      "name": "Errors by status message",
      "x": 12,
      "y": 12,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "pie",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "groupBy": "StatusMessage",
        "select": [
          {
            "aggFn": "count",
            "alias": "errors",
            "where": "SpanKind:Server AND StatusCode:Error",
            "whereLanguage": "lucene"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 18,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Slow routes & distribution"
      }
    },
    {
      "name": "Slowest routes (p95) — min 20 requests",
      "x": 0,
      "y": 21,
      "w": 24,
      "h": 6,
      "config": {
        "displayType": "table",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "sqlTemplate": "SELECT ServiceName AS \"Service\", route AS \"Route\", round(p95_ms, 1) AS \"p95 (ms)\", round(p50_ms, 1) AS \"p50 (ms)\", requests AS \"Requests\" FROM (\n  SELECT ServiceName,\n         SpanAttributes['http.route'] AS route,\n         quantile(0.95)(Duration) / 1e6 AS p95_ms,\n         quantile(0.5)(Duration) / 1e6 AS p50_ms,\n         count() AS requests\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}}\n  WHERE SpanKind = 'Server'\n    AND Timestamp >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND Timestamp <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND SpanAttributes['http.route'] != ''\n    AND $__filters\n  GROUP BY ServiceName, route\n  HAVING requests >= 20\n)\nORDER BY p95_ms DESC\nLIMIT 50"
      }
    },
    {
      "name": "Latency anomaly — p95 vs rolling baseline (±3σ control band)",
      "x": 0,
      "y": 27,
      "w": 24,
      "h": 7,
      "config": {
        "displayType": "line",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "sqlTemplate": "WITH points AS (\n  SELECT toStartOfInterval(Timestamp, INTERVAL 5 MINUTE) AS t,\n         quantile(0.95)(Duration)/1e6 AS p95_ms\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}}\n  WHERE SpanKind = 'Server' AND Timestamp > now() - INTERVAL 8 DAY AND $__filters\n  GROUP BY t\n),\nscored AS (\n  SELECT t, p95_ms,\n         avg(p95_ms)       OVER (ORDER BY t ROWS BETWEEN 288 PRECEDING AND 12 PRECEDING) AS base,\n         stddevPop(p95_ms) OVER (ORDER BY t ROWS BETWEEN 288 PRECEDING AND 12 PRECEDING) AS sigma\n  FROM points\n)\nSELECT t,\n       p95_ms,\n       base AS baseline_ms,\n       base + 3 * sigma AS upper_ms,\n       greatest(base - 3 * sigma, 0) AS lower_ms\nFROM scored\nWHERE t >= now() - INTERVAL 24 HOUR\nORDER BY t"
      }
    },
    {
      "name": "Server latency distribution (heatmap, seconds)",
      "x": 0,
      "y": 34,
      "w": 24,
      "h": 7,
      "config": {
        "displayType": "heatmap",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "where": "SpanKind:Server",
        "whereLanguage": "lucene",
        "numberFormat": {
          "output": "duration"
        },
        "select": [
          {
            "valueExpression": "Duration / 1000000000",
            "countExpression": "count()",
            "heatmapScaleType": "log",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 41,
      "w": 24,
      "h": 6,
      "config": {
        "displayType": "markdown",
        "markdown": "#### SLO & error budget\nAvailability = successful server requests / total server requests. Burn-rate windows (1h / 6h / 24h / 3d) are **fixed SLO windows** and intentionally ignore the time picker; a burn rate > 1 means the 99.9% budget is being spent too fast."
      }
    },
    {
      "name": "Availability (SLI)",
      "x": 0,
      "y": 47,
      "w": 12,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "if(StatusCode = 'Error', 0, 1)",
            "alias": "availability",
            "where": "SpanKind:Server",
            "whereLanguage": "lucene"
          }
        ],
        "colorRules": [
          {
            "operator": "lt",
            "value": 0.999,
            "color": "chart-warning",
            "label": "Below 99.9%"
          },
          {
            "operator": "lt",
            "value": 0.995,
            "color": "chart-error",
            "label": "Below 99.5%"
          }
        ]
      }
    },
    {
      "name": "Error budget remaining (window, SLO 99.9%)",
      "x": 12,
      "y": 47,
      "w": 12,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 1
        },
        "sqlTemplate": "SELECT 1 - (countIf(SpanKind = 'Server' AND StatusCode = 'Error') / nullIf(countIf(SpanKind = 'Server'), 0)) / 0.001 AS \"Budget remaining\"\nFROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}}\nWHERE Timestamp >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n  AND Timestamp <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n  AND $__filters",
        "colorRules": [
          {
            "operator": "lt",
            "value": 0.25,
            "color": "chart-warning",
            "label": "Budget low"
          },
          {
            "operator": "lt",
            "value": 0,
            "color": "chart-error",
            "label": "Budget exhausted"
          }
        ]
      }
    },
    {
      "name": "Multi-window burn rate (SLO 99.9%)",
      "x": 0,
      "y": 51,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "table",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "sqlTemplate": "WITH 0.001 AS budget\nSELECT window,\n       round(error_ratio, 5) AS error_ratio,\n       round(error_ratio / budget, 2) AS burn_rate\nFROM (\n  SELECT '1h' AS window, 1 AS ord,\n         countIf(SpanKind = 'Server' AND StatusCode = 'Error') / nullIf(countIf(SpanKind = 'Server'), 0) AS error_ratio\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}} WHERE Timestamp > now() - INTERVAL 1 HOUR AND $__filters\n  UNION ALL\n  SELECT '6h', 2,\n         countIf(SpanKind = 'Server' AND StatusCode = 'Error') / nullIf(countIf(SpanKind = 'Server'), 0)\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}} WHERE Timestamp > now() - INTERVAL 6 HOUR AND $__filters\n  UNION ALL\n  SELECT '24h', 3,\n         countIf(SpanKind = 'Server' AND StatusCode = 'Error') / nullIf(countIf(SpanKind = 'Server'), 0)\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}} WHERE Timestamp > now() - INTERVAL 24 HOUR AND $__filters\n  UNION ALL\n  SELECT '3d', 4,\n         countIf(SpanKind = 'Server' AND StatusCode = 'Error') / nullIf(countIf(SpanKind = 'Server'), 0)\n  FROM {{TRACES_SCHEMA}}.{{TRACES_TABLE}} WHERE Timestamp > now() - INTERVAL 3 DAY AND $__filters\n)\nORDER BY ord"
      }
    },
    {
      "name": "Availability over time (target 99.9%)",
      "x": 12,
      "y": 51,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "asRatio": true,
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "count",
            "alias": "good",
            "where": "SpanKind:Server AND NOT StatusCode:Error",
            "whereLanguage": "lucene"
          },
          {
            "aggFn": "count",
            "alias": "total",
            "where": "SpanKind:Server",
            "whereLanguage": "lucene"
          }
        ]
      }
    }
  ]
}
