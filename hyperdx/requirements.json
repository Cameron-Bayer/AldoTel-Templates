{
  "_comment": "Drives preflight.ps1/.sh (compatibility check) and documents per-dashboard requirements. tier is \"default\" (always populated on a full appliance deploy) or \"advanced\" (opt-in, needs optional data sources; imported only with -Advanced/--advanced). metricType maps to the otel_metrics_<type> table. required=false tiles degrade gracefully if the metric is absent.",
  "dashboards": [
    {
      "file": "clickhouse-health.json",
      "tmpl": "tmpl:clickhouse-health",
      "tier": "advanced",
      "name": "ClickHouse — Operations",
      "receivers": [
        "ClickHouse metrics scraped into OTel (Prometheus/clickhouse receiver)"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_Query"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_FailedQuery"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_SelectQuery"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_InsertQuery"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_InsertedRows"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_Query"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_Merge"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_PartMutation"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_ReadonlyReplica"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_MemoryTracking"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseAsyncMetrics_ReplicasMaxAbsoluteDelay"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_CachedReadBufferReadFromCacheBytes"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_AsyncInsertBytes"
        }
      ]
    },
    {
      "file": "kubernetes-infrastructure.json",
      "tmpl": "tmpl:k8s-infrastructure",
      "tier": "default",
      "name": "Kubernetes — Infrastructure",
      "receivers": [
        "kubeletstats receiver",
        "k8s_cluster receiver",
        "k8sobjects receiver (events.k8s.io) for the cluster-events tiles"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.node.cpu.usage"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.node.memory.usage"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.deployment.available"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.deployment.desired"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.pod.phase"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.container.restarts"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "k8s.pod.memory.usage"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.node.filesystem.usage"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.node.filesystem.capacity"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.pod.cpu_limit_utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.pod.memory_limit_utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.node.condition_ready"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.pod.cpu.usage"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.namespace.phase"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "k8s.pod.uptime"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "k8s.node.uptime"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.container.cpu_limit_utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "k8s.container.memory_limit_utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "container.uptime"
        },
        {
          "kind": "log",
          "required": false,
          "label": "cluster events (k8sobjects)",
          "where": "ScopeName:*k8sobjectsreceiver*"
        }
      ]
    },
    {
      "file": "services-red.json",
      "tmpl": "tmpl:services-red",
      "tier": "default",
      "name": "Services — RED (Rate / Errors / Duration)",
      "receivers": [
        "Application traces (OTLP)"
      ],
      "checks": [
        {
          "kind": "trace",
          "required": true,
          "label": "server spans",
          "where": "SpanKind:Server"
        },
        {
          "kind": "trace",
          "required": false,
          "label": "error spans",
          "where": "SpanKind:Server AND StatusCode:Error"
        }
      ]
    },
    {
      "file": "logs-overview.json",
      "tmpl": "tmpl:logs-overview",
      "tier": "default",
      "name": "Logs — Overview",
      "receivers": [
        "Application/container logs (filelog or OTLP)"
      ],
      "checks": [
        {
          "kind": "log",
          "required": true,
          "label": "log volume",
          "where": ""
        },
        {
          "kind": "log",
          "required": false,
          "label": "error logs",
          "where": "SeverityNumber:>=17 OR SeverityText:error OR SeverityText:fatal"
        }
      ]
    },
    {
      "file": "collector-health.json",
      "tmpl": "tmpl:collector-health",
      "tier": "advanced",
      "name": "OTel Collector — Pipeline Health",
      "receivers": [
        "OTel Collector internal telemetry scraped into OTel (Prometheus receiver on the collector's :8888 self-metrics)"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "otelcol_receiver_accepted_spans_total"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "sum",
          "metricName": "otelcol_exporter_sent_spans_total"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "otelcol_exporter_queue_size"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "otelcol_exporter_queue_capacity"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_processor_incoming_items_total"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_receiver_accepted_log_records_total"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_receiver_accepted_metric_points_total"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_scraper_scraped_metric_points"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "otelcol_process_memory_rss_bytes"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_process_cpu_seconds_total"
        }
      ]
    },
    {
      "file": "clickhouse-queryperf.json",
      "tmpl": "tmpl:clickhouse-queryperf",
      "tier": "advanced",
      "name": "ClickHouse — Query Performance & Errors",
      "receivers": [
        "ClickHouse metrics scraped into OTel (for the summary number tiles)",
        "Most tiles read system.query_log via Raw SQL — the HyperDX ClickHouse connection user must be able to SELECT from system.query_log, and query_log must be enabled"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_Query"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_MemoryTracking"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_FailedQuery"
        }
      ]
    },
    {
      "file": "clickhouse-storage-mergetree.json",
      "tmpl": "tmpl:ch-storage",
      "tier": "advanced",
      "name": "ClickHouse — Storage & MergeTree",
      "receivers": [
        "All tiles read system.parts / system.part_log via Raw SQL — the HyperDX ClickHouse connection user must be able to SELECT from system.parts and system.part_log (part_log must be enabled, which it is by default)"
      ],
      "checks": []
    },
    {
      "file": "clickhouse-keeper-replication.json",
      "tmpl": "tmpl:ch-keeper",
      "tier": "advanced",
      "name": "ClickHouse — Keeper & Replication",
      "receivers": [
        "ClickHouse metrics scraped into OTel (Keeper gauges/ProfileEvents)",
        "Replication tables read system.replicas / system.replication_queue via Raw SQL — these are empty on single-node installs and populate only on replicated/clustered ClickHouse"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_ZooKeeperSession"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_ZooKeeperWatch"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_KeeperAliveConnections"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_KeeperCommits"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "ClickHouseProfileEvents_KeeperRequestTotal"
        }
      ]
    },
    {
      "file": "executive-overview.json",
      "tmpl": "tmpl:exec-overview",
      "tier": "default",
      "name": "Executive Overview",
      "receivers": [
        "Application traces (OTLP), application/container logs, ClickHouse metrics and K8s metrics — this is a cross-cutting roll-up; tiles degrade gracefully when a given signal is absent"
      ],
      "checks": [
        {
          "kind": "trace",
          "required": false,
          "label": "server spans",
          "where": "SpanKind:Server"
        },
        {
          "kind": "log",
          "required": false,
          "label": "log volume",
          "where": ""
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "ClickHouseMetrics_Query"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "otelcol_receiver_accepted_spans_total"
        }
      ]
    },
    {
      "file": "host-os.json",
      "tmpl": "tmpl:host-os",
      "tier": "default",
      "name": "Host / OS Metrics",
      "receivers": [
        "hostmetrics receiver (system.* scrapers: cpu, memory, load, disk, network, paging)"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "system.cpu.utilization"
        },
        {
          "kind": "metric",
          "required": true,
          "metricType": "gauge",
          "metricName": "system.memory.utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "system.cpu.load_average.1m"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "gauge",
          "metricName": "system.swap.utilization"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "system.disk.io"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "sum",
          "metricName": "system.network.io"
        }
      ]
    },
    {
      "file": "metrics-histograms.json",
      "tmpl": "tmpl:metrics-histograms",
      "tier": "advanced",
      "name": "Latency Histograms",
      "receivers": [
        "Application OTLP explicit-bucket histogram metrics (http.*.duration / rpc.*.duration)",
        "ClickHouse Keeper histogram metrics (ClickHouseHistogramMetrics_keeper_*) for the Keeper latency tile"
      ],
      "checks": [
        {
          "kind": "metric",
          "required": true,
          "metricType": "histogram",
          "metricName": "http.server.duration"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "histogram",
          "metricName": "http.client.duration"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "histogram",
          "metricName": "rpc.server.duration"
        },
        {
          "kind": "metric",
          "required": false,
          "metricType": "histogram",
          "metricName": "ClickHouseHistogramMetrics_keeper_response_time_ms"
        }
      ]
    }
  ]
}
