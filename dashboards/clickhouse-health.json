{
  "name": "AldoTel · ClickHouse — Cluster Health",
  "tags": [
    "clickstack-templates",
    "clickhouse",
    "tmpl:clickhouse-health"
  ],
  "filters": [],
  "tiles": [
    {
      "name": "",
      "x": 0,
      "y": 0,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Cluster health — at a glance"
      }
    },
    {
      "name": "Running queries",
      "x": 0,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "last_value",
            "valueExpression": "Value",
            "metricName": "ClickHouseMetrics_Query",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Max replication lag (s)",
      "x": 6,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "max",
            "valueExpression": "Value",
            "metricName": "ClickHouseAsyncMetrics_ReplicasMaxAbsoluteDelay",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "colorRules": [
          {
            "operator": "gte",
            "value": 30,
            "color": "chart-error",
            "label": "Critical"
          },
          {
            "operator": "gte",
            "value": 5,
            "color": "chart-warning",
            "label": "Warning"
          }
        ]
      }
    },
    {
      "name": "Readonly replicas",
      "x": 12,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "max",
            "valueExpression": "Value",
            "metricName": "ClickHouseMetrics_ReadonlyReplica",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Memory tracking",
      "x": 18,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "numberFormat": {
          "output": "byte"
        },
        "select": [
          {
            "aggFn": "max",
            "valueExpression": "Value",
            "metricName": "ClickHouseMetrics_MemoryTracking",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 7,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Query activity"
      }
    },
    {
      "name": "Query rate (vs previous week)",
      "x": 0,
      "y": 10,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "compareToPreviousPeriod": true,
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "queries",
            "metricName": "ClickHouseProfileEvents_Query",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Failed queries",
      "x": 12,
      "y": 10,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "failed",
            "metricName": "ClickHouseProfileEvents_FailedQuery",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Inserted rows rate",
      "x": 0,
      "y": 16,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "rows",
            "metricName": "ClickHouseProfileEvents_InsertedRows",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "SELECT vs INSERT queries",
      "x": 12,
      "y": 16,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "select",
            "metricName": "ClickHouseProfileEvents_SelectQuery",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "insert",
            "metricName": "ClickHouseProfileEvents_InsertQuery",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 22,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Merges & mutations"
      }
    },
    {
      "name": "Merges in progress",
      "x": 0,
      "y": 25,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "max",
            "valueExpression": "Value",
            "alias": "merges",
            "metricName": "ClickHouseMetrics_Merge",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Mutations in progress",
      "x": 12,
      "y": 25,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "max",
            "valueExpression": "Value",
            "alias": "mutations",
            "metricName": "ClickHouseMetrics_PartMutation",
            "metricType": "gauge",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 31,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### I/O & cache"
      }
    },
    {
      "name": "Page-cache read bytes: cache vs source",
      "x": 0,
      "y": 34,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "numberFormat": {
          "output": "byte",
          "numericUnit": "bytes_iec"
        },
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "from cache",
            "metricName": "ClickHouseProfileEvents_CachedReadBufferReadFromCacheBytes",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "from source",
            "metricName": "ClickHouseProfileEvents_CachedReadBufferReadFromSourceBytes",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Async insert bytes",
      "x": 12,
      "y": 34,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "numberFormat": {
          "output": "byte",
          "numericUnit": "bytes_iec"
        },
        "select": [
          {
            "aggFn": "sum",
            "valueExpression": "Value",
            "alias": "bytes",
            "metricName": "ClickHouseProfileEvents_AsyncInsertBytes",
            "metricType": "sum",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    }
  ]
}