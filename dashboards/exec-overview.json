{
  "name": "AldoTel · Executive Overview",
  "tags": [
    "clickstack-templates",
    "overview",
    "tmpl:exec-overview"
  ],
  "filters": [
    {
      "type": "QUERY_EXPRESSION",
      "name": "Service",
      "expression": "ServiceName",
      "sourceId": "{{TRACES_SOURCE_ID}}",
      "whereLanguage": "sql"
    },
    {
      "type": "QUERY_EXPRESSION",
      "name": "Namespace",
      "expression": "ResourceAttributes['k8s.namespace.name']",
      "sourceId": "{{METRICS_SOURCE_ID}}",
      "sourceMetricType": "gauge",
      "whereLanguage": "sql"
    }
  ],
  "tiles": [
    {
      "name": "",
      "x": 0,
      "y": 0,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Service health — at a glance"
      }
    },
    {
      "name": "Span error rate (%)",
      "x": 0,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "if(StatusCode = 'Error', 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "colorRules": [
          {
            "operator": "gt",
            "value": 0.01,
            "color": "chart-warning",
            "label": "Elevated"
          },
          {
            "operator": "gt",
            "value": 0.05,
            "color": "chart-error",
            "label": "High"
          }
        ]
      }
    },
    {
      "name": "Trace volume (spans)",
      "x": 6,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "select": [
          {
            "aggFn": "count",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Span latency p95",
      "x": 12,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "numberFormat": {
          "output": "duration"
        },
        "select": [
          {
            "aggFn": "quantile",
            "level": 0.95,
            "valueExpression": "Duration / 1000000",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    },
    {
      "name": "Log error rate (%)",
      "x": 18,
      "y": 3,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "sourceId": "{{LOGS_SOURCE_ID}}",
        "numberFormat": {
          "output": "percent",
          "mantissa": 3
        },
        "select": [
          {
            "aggFn": "avg",
            "valueExpression": "if(SeverityText IN ('Error', 'Fatal'), 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "colorRules": [
          {
            "operator": "gt",
            "value": 0.01,
            "color": "chart-warning",
            "label": "Elevated"
          },
          {
            "operator": "gt",
            "value": 0.05,
            "color": "chart-error",
            "label": "High"
          }
        ]
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 7,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Platform — at a glance"
      }
    },
    {
      "name": "ClickHouse failed queries",
      "x": 0,
      "y": 10,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT sum(d) AS \"Failed queries\" FROM (\n  SELECT max(Value) - min(Value) AS d\n  FROM {{METRICS_SCHEMA}}.otel_metrics_sum\n  WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND MetricName = 'ClickHouseProfileEvents_FailedQuery'\n  GROUP BY ResourceAttributes['service.instance.id']\n)"
      }
    },
    {
      "name": "ClickHouse running queries",
      "x": 6,
      "y": 10,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT sum(v) AS \"Running queries\" FROM (\n  SELECT argMax(Value, TimeUnix) AS v\n  FROM {{METRICS_SCHEMA}}.otel_metrics_gauge\n  WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND MetricName = 'ClickHouseMetrics_Query'\n  GROUP BY ResourceAttributes['service.instance.id']\n)"
      }
    },
    {
      "name": "K8s nodes ready",
      "x": 12,
      "y": 10,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT countIf(ready = 1) AS \"Nodes ready\" FROM (\n  SELECT ResourceAttributes['k8s.node.name'] AS node, argMax(Value, TimeUnix) AS ready\n  FROM {{METRICS_SCHEMA}}.otel_metrics_gauge\n  WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND MetricName = 'k8s.node.condition_ready'\n  GROUP BY node\n)"
      }
    },
    {
      "name": "Collector refused spans",
      "x": 18,
      "y": 10,
      "w": 6,
      "h": 4,
      "config": {
        "displayType": "number",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT sum(d) AS \"Refused spans\" FROM (\n  SELECT max(Value) - min(Value) AS d\n  FROM {{METRICS_SCHEMA}}.otel_metrics_sum\n  WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n    AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n    AND MetricName = 'otelcol_receiver_refused_spans_total'\n  GROUP BY ResourceAttributes['service.instance.id']\n)"
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 14,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Top services"
      }
    },
    {
      "name": "Services by error rate — click a row to open Traces",
      "x": 0,
      "y": 17,
      "w": 12,
      "h": 7,
      "config": {
        "displayType": "table",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "groupByColumnsOnLeft": true,
        "orderBy": "err_pct DESC",
        "select": [
          {
            "alias": "spans",
            "aggFn": "count",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "alias": "err_pct",
            "aggFn": "avg",
            "valueExpression": "if(StatusCode = 'Error', 100, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "onClick": {
          "type": "search",
          "target": {
            "mode": "id",
            "id": "{{TRACES_SOURCE_ID}}"
          },
          "whereTemplate": "ServiceName = '{{ServiceName}}'",
          "whereLanguage": "sql"
        }
      }
    },
    {
      "name": "Services by log errors — click a row to open Logs",
      "x": 12,
      "y": 17,
      "w": 12,
      "h": 7,
      "config": {
        "displayType": "table",
        "sourceId": "{{LOGS_SOURCE_ID}}",
        "groupBy": "ServiceName",
        "groupByColumnsOnLeft": true,
        "orderBy": "errors DESC",
        "select": [
          {
            "alias": "logs",
            "aggFn": "count",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "alias": "errors",
            "aggFn": "sum",
            "valueExpression": "if(SeverityText IN ('Error', 'Fatal'), 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ],
        "onClick": {
          "type": "search",
          "target": {
            "mode": "id",
            "id": "{{LOGS_SOURCE_ID}}"
          },
          "whereTemplate": "ServiceName = '{{ServiceName}}'",
          "whereLanguage": "sql"
        }
      }
    },
    {
      "name": "",
      "x": 0,
      "y": 24,
      "w": 24,
      "h": 3,
      "config": {
        "displayType": "markdown",
        "markdown": "#### Traffic & ingest"
      }
    },
    {
      "name": "Ingest throughput — spans accepted vs refused",
      "x": 0,
      "y": 27,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "configType": "sql",
        "connectionId": "{{CONNECTION_ID}}",
        "sourceId": "{{METRICS_SOURCE_ID}}",
        "sqlTemplate": "SELECT ts, kind, sum(greatest(cum - prev, 0)) AS value FROM (\n  SELECT ts, inst, kind, cum, lagInFrame(cum, 1, cum) OVER (PARTITION BY kind, inst ORDER BY ts) AS prev\n  FROM (\n    SELECT toStartOfInterval(TimeUnix, INTERVAL {intervalSeconds:Int64} SECOND) AS ts,\n           ResourceAttributes['service.instance.id'] AS inst,\n           if(MetricName = 'otelcol_receiver_accepted_spans_total', 'accepted', 'refused') AS kind,\n           max(Value) AS cum\n    FROM {{METRICS_SCHEMA}}.otel_metrics_sum\n    WHERE TimeUnix >= fromUnixTimestamp64Milli({startDateMilliseconds:Int64})\n      AND TimeUnix <= fromUnixTimestamp64Milli({endDateMilliseconds:Int64})\n      AND MetricName IN ('otelcol_receiver_accepted_spans_total', 'otelcol_receiver_refused_spans_total')\n    GROUP BY ts, inst, kind\n  )\n)\nGROUP BY ts, kind\nORDER BY ts"
      }
    },
    {
      "name": "Request rate & errors (traces)",
      "x": 12,
      "y": 27,
      "w": 12,
      "h": 6,
      "config": {
        "displayType": "line",
        "sourceId": "{{TRACES_SOURCE_ID}}",
        "select": [
          {
            "alias": "requests",
            "aggFn": "count",
            "where": "",
            "whereLanguage": "sql"
          },
          {
            "alias": "errors",
            "aggFn": "sum",
            "valueExpression": "if(StatusCode = 'Error', 1, 0)",
            "where": "",
            "whereLanguage": "sql"
          }
        ]
      }
    }
  ]
}